# 🐳 Docker / Database Server Configuration
# These values define how the database is created in Docker.
# IMPORTANT: These MUST match the values in your /backend/.env for the app to connect.

DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=las_analyzer

# AWS ECR (Optional: Used only for production CI/CD)
# ECR_REGISTRY=your-account-id.dkr.ecr.us-east-1.amazonaws.com