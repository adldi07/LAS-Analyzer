# ⚙️ Backend Application Configuration

# Application
PORT=3000
NODE_ENV=development

# 🗄️ Database Connection
# IMPORTANT: These values MUST MATCH the root /.env file for the connection to work.

# Option 1: Full Connection String (Standard)
DATABASE_URL=postgresql://postgres:admin123@localhost:5432/las_analyzer

# Option 2: Individual Variables (Recommended for Docker/Advanced Setup)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=las_analyzer
DB_PORT=5432

# ☁️ AWS S3 (Required for File Uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_S3_BUCKET=las-files-dev

# 🧠 AI Intelligence (Required for Interpretations)
CLAUDE_API_KEY=sk-ant-your-key-here

# 🔒 Security
CORS_ORIGIN=http://localhost:5173