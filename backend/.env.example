# .env.example
PORT=3000
NODE_ENV=development

# Database (Option 1: Connection String)
DATABASE_URL=postgresql://postgres:admin123@localhost:5432/las_analyzer

# Database (Option 2: Individual Vars - Recommended for Docker)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=las_analyzer
DB_PORT=5432

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_S3_BUCKET=las-files-dev

# Claude API
CLAUDE_API_KEY=sk-ant-your-key-here

# CORS
CORS_ORIGIN=http://localhost:5173